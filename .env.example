# Copy this file to `.env` for local live-provider testing.
# Real `.env` files are gitignored. Do not commit secrets.
#
# Load manually before running provider smokes:
#   set -a; source .env; set +a
# or use direnv with an untracked `.envrc` if preferred.

# Direct Context7 REST API calls.
CONTEXT7_API_KEY=

# Firecrawl scrape fallback. Live Firecrawl commands may spend requests.
FIRECRAWL_API_KEY=

# Exa is used from Codex MCP/session tools; codex-research only reports readiness.
EXA_API_KEY=

# GitHub auth normally comes from `gh auth token`.
# Set one of these only when `gh` auth is unavailable or a specific token is needed.
GITHUB_TOKEN=
# GH_TOKEN=

# Optional local overrides.
# CODEX_RESEARCH_HOME=
# CODEX_RESEARCH_CONFIG=
