{
  "schema": "dev-skills.hardened-codex-release.v1",
  "name": "hardened-codex",
  "description": "Tracked source manifest for hardened Codex custom subagents, public overlays, local-only private overlays, and install smoke gates.",
  "public_sources": [
    "subagents/hardened-codex/README.md",
    "subagents/hardened-codex/ROLE_CATALOG.md",
    "subagents/hardened-codex/agents/global",
    "subagents/hardened-codex/agents/overlays/docmind",
    "subagents/hardened-codex/agents/overlays/tooling",
    "subagents/hardened-codex/scripts/render_agents.py",
    "subagents/hardened-codex/scripts/sync_agents.py",
    "subagents/hardened-codex/overlays.local.example.json",
    "subagents/hardened-codex/roles.local.example.json"
  ],
  "private_local_only": [
    {
      "path": "subagents/hardened-codex/overlays.local.json",
      "reason": "Local project paths and private overlay names."
    },
    {
      "path": "subagents/hardened-codex/overlays.local.*.json",
      "reason": "Alternate local install manifests."
    },
    {
      "path": "subagents/hardened-codex/roles.local.json",
      "reason": "Private role source definitions."
    },
    {
      "path": "subagents/hardened-codex/roles.local.*.json",
      "reason": "Alternate private role source manifests."
    },
    {
      "path": "subagents/hardened-codex/agents/overlays/*/",
      "reason": "Repo-private overlay TOML files unless explicitly unignored as public overlays."
    }
  ],
  "explicit_public_overlay_allowlist": [
    "docmind",
    "tooling"
  ],
  "dry_run_first": [
    "PYTHONDONTWRITEBYTECODE=1 python3 subagents/hardened-codex/scripts/sync_agents.py --global --all-overlays --dry-run",
    "PYTHONDONTWRITEBYTECODE=1 python3 subagents/hardened-codex/scripts/sync_agents.py --all-local-overlays --dry-run"
  ],
  "apply": [
    "PYTHONDONTWRITEBYTECODE=1 python3 subagents/hardened-codex/scripts/sync_agents.py --global --all-overlays",
    "PYTHONDONTWRITEBYTECODE=1 python3 subagents/hardened-codex/scripts/sync_agents.py --all-local-overlays"
  ],
  "rollback": [
    "Global backups are written below ~/.codex/agent-backups/global-<timestamp>.",
    "Project overlay backups are written below <project>/.codex/agent-backups/<overlay>-<timestamp>.",
    "Restore the backed-up TOML files into the matching agents directory, then rerun validation."
  ],
  "smoke_matrix": [
    {
      "name": "validate release manifest",
      "command": "PYTHONDONTWRITEBYTECODE=1 python3 subagents/hardened-codex/scripts/sync_agents.py --validate-release-manifest"
    },
    {
      "name": "validate tracked roles",
      "command": "PYTHONDONTWRITEBYTECODE=1 python3 skills/subagent-creator/scripts/subagent_creator.py validate subagents/hardened-codex/agents"
    },
    {
      "name": "preview global plus public overlays",
      "command": "PYTHONDONTWRITEBYTECODE=1 python3 subagents/hardened-codex/scripts/sync_agents.py --global --all-overlays --dry-run"
    },
    {
      "name": "validate public overlay sources",
      "command": "PYTHONDONTWRITEBYTECODE=1 python3 subagents/hardened-codex/scripts/sync_agents.py --global --all-overlays --validate-sources"
    },
    {
      "name": "prove local manifests stay ignored",
      "command": "git check-ignore -v subagents/hardened-codex/overlays.local.json subagents/hardened-codex/roles.local.json subagents/hardened-codex/agents/overlays/private-repo/private_repo_reviewer.toml"
    }
  ]
}
